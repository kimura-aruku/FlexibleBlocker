{
  "manifest_version": 3,
  "name": "FlexibleBlocker",
  "version": "1.0.0",
  "description": "時間帯ごとに指定サイトへのアクセスを制限し、制限時間中は警告ページにリダイレクトする拡張機能。",
  "permissions": [
    "storage",
    "webNavigation",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "FlexibleBlocker"
  },
  "options_page": "options.html"
} 